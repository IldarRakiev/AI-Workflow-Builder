TELEGRAM_BOT_TOKEN=your_token_here
OPENROUTER_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# n8n integration (optional — bot works without it)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# Billing (optional — bot works without it, /services /topup /billing won't work)
# PAYMENT_PROVIDER_TOKEN: BotFather → выбери бота → Payments → ЮKassa → получи токен
# OPENROUTER_ADMIN_KEY:   Management API key (sk_or_mgmt_...) — openrouter.ai/settings/keys
# FALLBACK_API_KEY:       Дешёвый ключ для fallback когда квота пользователя исчерпана
# RUB_PER_USD:            Курс рубля (обновляй вручную при сильных изменениях)
# LLM_SHARE:              Доля от суммы платежа, которая идёт в LLM-бюджет (0.77 = 77%)
PAYMENT_PROVIDER_TOKEN=
OPENROUTER_ADMIN_KEY=
FALLBACK_API_KEY=
FALLBACK_MODEL=openai/gpt-4o-mini
RUB_PER_USD=95.0
LLM_SHARE=0.77